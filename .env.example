# ---- Supabase (Project Settings → API) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key — server-only. Used by cron jobs, /api/ingest and the MCP server.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- App ----
# Public URL of the deployed app (no trailing slash). Used for OAuth redirects + bookmarklet.
APP_URL=https://your-crm.vercel.app
# Random secret; Vercel Cron sends it as Authorization: Bearer <CRON_SECRET>.
# Vercel sets this automatically when defined in project env vars.
CRON_SECRET=generate-a-long-random-string
# Bearer token for the generic /api/ingest endpoint (iMessage/WhatsApp bridges, scripts).
INGEST_TOKEN=generate-another-long-random-string

# ---- Digest email (Resend free tier: 100 emails/day) ----
RESEND_API_KEY=re_...
DIGEST_FROM="AK Capital CRM <crm@yourdomain.com>"
DIGEST_TO=kevin@akcapital.fund

# ---- Google (your own free Google Cloud project; OAuth consent: internal/testing) ----
# Enable APIs: Gmail API, Google Calendar API, People API.
# Authorized redirect URI: {APP_URL}/api/google/oauth/callback
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ---- MailerLite (free tier: 1,000 subscribers) ----
MAILERLITE_API_KEY=eyJ...
